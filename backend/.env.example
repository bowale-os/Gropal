# FortiFi Backend — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env.

# Gemini AI (get from aistudio.google.com)
GEMINI_API_KEY=

# Plaid (get from dashboard.plaid.com — use sandbox credentials for dev)
PLAID_CLIENT_ID=
PLAID_SECRET=

# Database (NeonDB PostgreSQL URL or sqlite:///./fortifi.db for local dev)
DATABASE_URL=sqlite:///./fortifi.db

# App
SECRET_KEY=change_me_to_a_random_32_char_string
ENVIRONMENT=development

# Rate limiting for Gemini AI calls
GEMINI_RATE_LIMIT_PER_HOUR=20
